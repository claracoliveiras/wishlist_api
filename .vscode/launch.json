{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI (uvicorn, reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--log-level",
        "debug"
      ],
      "subProcess": true,
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": true,
      "console": "integratedTerminal"
    }
  ]
}
